# Supabase Postgres pooler connection string (server-side imports and migrations only)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres"

# Safe public credentials used by SvelteKit's read-only Supabase client
PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_REPLACE_ME"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
