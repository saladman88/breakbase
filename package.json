{
	"name": "breakbase",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"data:extract:bc-one-history": "python scripts/extract-red-bull-bc-one-history.py",
		"db:audit:bc-one": "node --env-file=.env scripts/audit-red-bull-bc-one.mjs",
		"db:import:bc-one-2018": "node --env-file=.env scripts/import-red-bull-bc-one-2025.mjs 2018",
		"db:import:bc-one-2019": "node --env-file=.env scripts/import-red-bull-bc-one-2025.mjs 2019",
		"db:import:bc-one-2020": "node --env-file=.env scripts/import-red-bull-bc-one-2025.mjs 2020",
		"db:import:bc-one-2021": "node --env-file=.env scripts/import-red-bull-bc-one-2025.mjs 2021",
		"db:import:bc-one-2022": "node --env-file=.env scripts/import-red-bull-bc-one-2025.mjs 2022",
		"db:import:bc-one-2023": "node --env-file=.env scripts/import-red-bull-bc-one-2025.mjs 2023",
		"db:import:bc-one-2024": "node --env-file=.env scripts/import-red-bull-bc-one-2025.mjs 2024",
		"db:import:bc-one-2025": "node --env-file=.env scripts/import-red-bull-bc-one-2025.mjs 2025",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@chromatic-com/storybook": "^5.2.1",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.18.2",
		"@playwright/test": "^1.60.0",
		"@storybook/addon-a11y": "^10.5.3",
		"@storybook/addon-docs": "^10.5.3",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.5.3",
		"@storybook/sveltekit": "^10.5.3",
		"@sveltejs/adapter-vercel": "next",
		"@sveltejs/kit": "next",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.8",
		"better-auth": "~1.4.21",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.5.3",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.60.0",
		"postgres": "^3.4.9",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"storybook": "^10.5.3",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@supabase/supabase-js": "2.110.7"
	}
}
